const markup = icons[name];
---

<svg
	class={className}
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.8"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden={title ? undefined : 'true'}
	role={title ? 'img' : undefined}
>
	{title && <title>{title}</title>}
	<g set:html={markup} />
</svg>
