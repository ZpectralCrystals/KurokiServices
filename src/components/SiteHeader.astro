---
import type { NavLink } from '../data/landing';
import Icon from './Icon.astro';

interface Props {
	links: NavLink[];
}

const { links } = Astro.props;
---

<header class="site-header">
	<div class="shell site-header__inner">
		<a class="brand" href="#top" aria-label="Volver al inicio">
			<span class="brand__mark">
				<Icon name="layers" class="brand__icon" />
			</span>
			<span class="brand__copy">
				<strong>Software Delivery Model</strong>
				<small>Proceso, metodologia e IA aplicada</small>
			</span>
		</a>

		<nav class="site-nav" aria-label="Principal">
			{
				links.map((link) => (
					<a href={link.href}>{link.label}</a>
				))
			}
		</nav>

		<a class="button button--primary button--small" href="#contacto">Solicitar propuesta</a>
	</div>
</header>
