---
import Icon from '../components/Icon.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import {
	aboutPoints,
	aiUseCases,
	companyData,
	differentiators,
	heroHighlights,
	mailtoUrl,
	missionVision,
	navLinks,
	projectTypes,
	services,
	specializedSolutions,
	technologies,
	whatsappUrl,
	workProcess,
} from '../data/landing';
import Layout from '../layouts/Layout.astro';
import '../styles/landing.css';
---

<Layout bodyClass="landing-body">
	<SiteHeader links={navLinks} />

	<main class="landing-page" id="top">
		<section class="hero-section" aria-labelledby="hero-title">
			<div class="shell hero-grid">
				<div class="hero-copy">
					<p class="eyebrow">{companyData.descriptor}</p>
					<h1 class="hero-title" id="hero-title">Transformamos ideas en soluciones digitales</h1>
					<p class="hero-text">
						Diseñamos y desarrollamos aplicaciones móviles, plataformas web y software a medida
						para ayudar a empresas y emprendimientos a digitalizar sus procesos, mejorar sus
						servicios y construir productos preparados para crecer.
					</p>

					<div class="hero-actions" aria-label="Acciones principales">
						<a class="button button--primary" href="#contacto">
							<span>Solicitar una cotización</span>
							<Icon name="arrow-right" class="button__icon" />
						</a>
						<a class="button button--ghost" href="#servicios">Conocer nuestros servicios</a>
					</div>

					<p class="hero-note">
						Desarrollo web y mobile con arquitectura escalable, comunicación directa y uso
						responsable de inteligencia artificial.
					</p>
				</div>

				<div class="hero-brand" aria-label="Identidad de Kuroki">
					<img src={companyData.logo} alt={companyData.logoAlt} width="1711" height="399" />
					<div class="hero-brand__content">
						<strong>{companyData.slogan}</strong>
						<p>{companyData.commercialPhrase}</p>
					</div>
				</div>
			</div>

			<div class="shell hero-highlight-grid" aria-label="Servicios destacados">
				{
					heroHighlights.map((item) => (
						<article class="compact-card">
							<span class="icon-box">
								<Icon name={item.icon} />
							</span>
							<h2>{item.title}</h2>
							<p>{item.description}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="section" id="nosotros" aria-labelledby="nosotros-title">
			<div class="shell two-column">
				<div class="section-copy">
					<p class="eyebrow">Quienes somos</p>
					<h2 class="section-title" id="nosotros-title">Tecnología construida con experiencia y confianza</h2>
					{
						aboutPoints.map((point) => (
							<p class="section-text">{point}</p>
						))
					}
					<p class="quote">
						No solo desarrollamos software. Analizamos el negocio para construir una solución que
						realmente pueda utilizarse, mantenerse y crecer.
					</p>
				</div>

				<div class="mini-card-grid">
					{
						missionVision.map((item) => (
							<article class="mini-card">
								<h3>{item.title}</h3>
								<p>{item.text}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section section--muted" id="servicios" aria-labelledby="servicios-title">
			<div class="shell">
				<div class="section-heading">
					<p class="eyebrow">Servicios</p>
					<h2 class="section-title" id="servicios-title">Soluciones digitales para cada etapa de tu negocio</h2>
				</div>

				<div class="service-grid">
					{
						services.map((service) => (
							<article class="service-card">
								<span class="icon-box">
									<Icon name={service.icon} />
								</span>
								<h3>{service.title}</h3>
								<p>{service.description}</p>
								{service.features && (
									<ul>
										{service.features.slice(0, 6).map((feature) => (
											<li>{feature}</li>
										))}
									</ul>
								)}
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section" id="soluciones" aria-labelledby="soluciones-title">
			<div class="shell">
				<div class="section-heading">
					<p class="eyebrow">Soluciones especializadas</p>
					<h2 class="section-title" id="soluciones-title">Soluciones preparadas para distintos negocios</h2>
					<p class="section-text">
						Soluciones en desarrollo y personalizables según las necesidades de cada cliente.
					</p>
				</div>

				<div class="solution-grid">
					{
						specializedSolutions.map((solution) => (
							<article class="solution-card">
								<h3>{solution.title}</h3>
								<p>{solution.description}</p>
								<ul>
									{solution.items.map((item) => (
										<li>
											<Icon name="check-circle" />
											<span>{item}</span>
										</li>
									))}
								</ul>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section section--dark" id="ia" aria-labelledby="ia-title">
			<div class="shell two-column">
				<div class="section-copy">
					<p class="eyebrow">IA responsable</p>
					<h2 class="section-title" id="ia-title">Inteligencia artificial con supervisión profesional</h2>
					<p class="section-text">
						Utilizamos herramientas de inteligencia artificial para optimizar determinadas etapas
						del desarrollo, reducir tareas repetitivas, mejorar la documentación, apoyar la creación
						de pruebas y acelerar el prototipado.
					</p>
					<p class="section-text">
						La inteligencia artificial no reemplaza el análisis ni la supervisión profesional. Cada
						solución es revisada por especialistas para garantizar calidad, seguridad,
						mantenibilidad y coherencia con los objetivos del proyecto.
					</p>
				</div>

				<div class="check-panel">
					<h3>Áreas donde puede utilizarse</h3>
					<ul>
						{
							aiUseCases.map((item) => (
								<li>
									<Icon name="check-circle" />
									<span>{item}</span>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</section>

		<section class="section" id="proceso" aria-labelledby="proceso-title">
			<div class="shell">
				<div class="section-heading">
					<p class="eyebrow">Como trabajamos</p>
					<h2 class="section-title" id="proceso-title">Un proceso claro de principio a fin</h2>
				</div>

				<div class="process-list">
					{
						workProcess.map((step, index) => (
							<article class="process-item">
								<span>{String(index + 1).padStart(2, '0')}</span>
								<h3>{step.title}</h3>
								<p>{step.text}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section section--muted" aria-labelledby="diferenciales-title">
			<div class="shell two-column">
				<div class="section-copy">
					<p class="eyebrow">Diferenciales</p>
					<h2 class="section-title" id="diferenciales-title">¿Por qué trabajar con Kuroki?</h2>
					<p class="quote">
						Puedes delegar tu proyecto con la confianza de que será gestionado con responsabilidad,
						comunicación y criterio técnico.
					</p>
				</div>

				<ul class="feature-list">
					{
						differentiators.map((item) => (
							<li>
								<Icon name="check-circle" />
								<span>{item}</span>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section class="section" aria-labelledby="tecnologias-title">
			<div class="shell">
				<div class="section-heading">
					<p class="eyebrow">Tecnologías</p>
					<h2 class="section-title" id="tecnologias-title">Tecnologías con las que trabajamos</h2>
				</div>

				<div class="tech-grid">
					{
						technologies.map((group) => (
							<article class="tech-card">
								<h3>{group.title}</h3>
								<div>
									{group.items.map((item) => (
										<span>{item}</span>
									))}
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="cta-section" aria-labelledby="cta-title">
			<div class="shell cta-inner">
				<div>
					<p class="eyebrow">Cotización</p>
					<h2 class="section-title" id="cta-title">¿Tienes una idea o un proceso que quieres digitalizar?</h2>
					<p class="section-text">
						Conversemos sobre tu proyecto y encontremos una solución tecnológica adecuada para tu
						negocio.
					</p>
				</div>
				<div class="cta-actions">
					<a class="button button--primary" href="#contacto">Solicitar cotización</a>
					<a class="button button--ghost" href={whatsappUrl} target="_blank" rel="noreferrer">
						Hablar por WhatsApp
					</a>
				</div>
			</div>
		</section>

		<section class="section" id="contacto" aria-labelledby="contacto-title">
			<div class="shell contact-grid">
				<div class="contact-copy">
					<p class="eyebrow">Contacto</p>
					<h2 class="section-title" id="contacto-title">Hablemos de tu proyecto</h2>
					<dl class="contact-list">
						<div>
							<dt>Nombre comercial</dt>
							<dd>{companyData.name}</dd>
						</div>
						<div>
							<dt>Persona de contacto</dt>
							<dd>{companyData.contactPerson}</dd>
						</div>
						<div>
							<dt>Teléfono comercial</dt>
							<dd><a href={`tel:+51${companyData.phones.commercial}`}>{companyData.phones.commercial}</a></dd>
						</div>
						<div>
							<dt>Teléfono de contacto</dt>
							<dd><a href={`tel:+51${companyData.phones.contact}`}>{companyData.phones.contact}</a></dd>
						</div>
						<div>
							<dt>Correo provisional</dt>
							<dd>
								<a href={mailtoUrl}>{companyData.email}</a>
								{!companyData.emailConfirmed && <span>Por confirmar</span>}
							</dd>
						</div>
						<div>
							<dt>Horario de atención</dt>
							<dd>{companyData.schedule}</dd>
						</div>
					</dl>
				</div>

				<form class="contact-form" action={mailtoUrl} method="get" data-contact-form data-contact-email={companyData.email}>
					<div class="form-row">
						<label for="name">Nombre</label>
						<input id="name" name="name" type="text" autocomplete="name" required />
					</div>
					<div class="form-row">
						<label for="company">Empresa</label>
						<input id="company" name="company" type="text" autocomplete="organization" required />
					</div>
					<div class="form-row">
						<label for="email">Correo</label>
						<input id="email" name="email" type="email" autocomplete="email" required />
					</div>
					<div class="form-row">
						<label for="phone">Teléfono</label>
						<input id="phone" name="phone" type="tel" autocomplete="tel" required />
					</div>
					<div class="form-row">
						<label for="project-type">Tipo de proyecto</label>
						<select id="project-type" name="project-type" required>
							{projectTypes.map((type) => <option value={type.value}>{type.label}</option>)}
						</select>
					</div>
					<div class="form-row">
						<label for="budget">Presupuesto aproximado <span>Opcional</span></label>
						<input id="budget" name="budget" type="text" />
					</div>
					<div class="form-row form-row--full">
						<label for="message">Descripción del proyecto</label>
						<textarea id="message" name="message" rows="5" required></textarea>
					</div>
					<label class="checkbox-row">
						<input type="checkbox" name="privacy" required />
						<span>Acepto que Kuroki utilice estos datos para responder mi solicitud.</span>
					</label>
					<p class="form-note">
						El formulario queda listo para conectar a un backend. Mientras tanto, puedes contactarnos
						por WhatsApp o correo.
					</p>
					<div class="form-actions">
						<button class="button button--primary" type="submit">Enviar solicitud</button>
						<a class="button button--ghost" href={whatsappUrl} target="_blank" rel="noreferrer">
							Preparar WhatsApp
						</a>
					</div>
				</form>
			</div>
		</section>
	</main>

	<SiteFooter links={navLinks} />
</Layout>

<script>
	const contactForm = document.querySelector<HTMLFormElement>('[data-contact-form]');

	contactForm?.addEventListener('submit', (event) => {
		event.preventDefault();
		if (!contactForm.checkValidity()) {
			contactForm.reportValidity();
			return;
		}

		const data = new FormData(contactForm);
		const email = contactForm.dataset.contactEmail ?? 'hola@kservices.com';
		const lines = [
			'Hola, me gustaria solicitar informacion sobre el desarrollo de un proyecto de software con Kuroki.',
			'',
			`Nombre: ${data.get('name') ?? ''}`,
			`Empresa: ${data.get('company') ?? ''}`,
			`Correo: ${data.get('email') ?? ''}`,
			`Telefono: ${data.get('phone') ?? ''}`,
			`Tipo de proyecto: ${data.get('project-type') ?? ''}`,
			`Presupuesto aproximado: ${data.get('budget') ?? 'No indicado'}`,
			'',
			`Descripcion: ${data.get('message') ?? ''}`,
		];

		window.location.href = `mailto:${email}?subject=${encodeURIComponent(
			'Solicitud de cotizacion - Kuroki',
		)}&body=${encodeURIComponent(lines.join('\n'))}`;
	});
</script>
