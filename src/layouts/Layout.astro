---
interface Props {
	title?: string;
	description?: string;
	bodyClass?: string;
}

const {
	title = 'Software Delivery Model | Landing page',
	description = 'Landing page ejecutiva creada con Astro y TypeScript.',
	bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class={bodyClass}>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		font-family: 'Manrope', 'Avenir Next', 'Segoe UI', sans-serif;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: #f8fafc;
		color: #0f172a;
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: inherit;
	}

	img,
	svg {
		display: block;
		max-width: 100%;
	}
</style>
